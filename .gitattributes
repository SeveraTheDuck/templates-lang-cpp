# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# -- Text ----------------------------------------------------------------------
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf
*.nix   text eol=lf
*.just  text eol=lf

# -- Binary --------------------------------------------------------------------
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
