#!/usr/bin/env bash
# Expand tests/pipelines/**/*.json into a GitHub Actions matrix. Each suite
# becomes (preset x compiler) cells; the build job runs exactly that suite via
# `ctest -L <label>` (LABEL == target name, set by add_project_test). The
# compiler axis is fixed at generation time from compiler_matrix.
set -euo pipefail
{%- if compiler_matrix == 'both' %}
compilers='["gcc", "clang"]'
{%- elif compiler_matrix == 'gcc' %}
compilers='["gcc"]'
{%- else %}
compilers='["clang"]'
{%- endif %}

include=$(
  find tests/pipelines -type f -name '*.json' -print0 \
    | xargs -0 cat \
    | jq -s --argjson compilers "$compilers" \
        '[ .[].suites[]
           | . as $s
           | $s.presets[] as $preset
           | $compilers[] as $compiler
           | { compiler: $compiler, preset: $preset, label: $s.label } ]'
)

echo "matrix=$(jq -cn --argjson include "$include" '{include: $include}')" >> "$GITHUB_OUTPUT"
